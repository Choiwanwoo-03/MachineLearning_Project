# ════════════════════════════════════════
# 가상환경
# ════════════════════════════════════════
venv/
.venv/
env/
.env/


# ════════════════════════════════════════
# 데이터 파일 (대용량 — Git LFS 또는 공유 드라이브 사용)
# ════════════════════════════════════════
data/raw/
data/processed/
data/features/
data/results/

# 학습된 모델 파일
data/models/
*.h5
*.pt
*.pth
# 단, 소형 파라미터 JSON은 예외
!data/models/lgbm_best_params.json
!data/models/year_trend.json

# 시각화 출력 (재생성 가능)
data/figures/

# 폴더 구조 유지용 .gitkeep 파일은 추적
!**/.gitkeep


# ════════════════════════════════════════
# 데이터 포맷
# ════════════════════════════════════════
*.parquet
*.xls


# ════════════════════════════════════════
# 환경 변수 및 API 키 (절대 업로드 금지)
# ════════════════════════════════════════
.env
.env.*
config/secrets.py
config/api_keys.py
**/api_key*.py
**/secret*.py


# ════════════════════════════════════════
# Python 캐시
# ════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python


# ════════════════════════════════════════
# Jupyter Notebook
# ════════════════════════════════════════
.ipynb_checkpoints/
*.ipynb_checkpoints


# ════════════════════════════════════════
# IDE 설정
# ════════════════════════════════════════
.vscode/
.idea/
*.sublime-project
*.sublime-workspace


# ════════════════════════════════════════
# OS 관련
# ════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini


# ════════════════════════════════════════
# 로그 / 임시 파일
# ════════════════════════════════════════
*.log
*.tmp
*.bak
